# Copiar a .env.production y ajustar antes de desplegar
# cp .env.production.example .env.production

# ─── Base de datos (contenedor postgres) ───
POSTGRES_USER=yallpos
POSTGRES_PASSWORD=cambiar-password-seguro-aqui
POSTGRES_DB=yallpos

# Primera instalación: RUN_SEED=true (Restaurante de Yall + usuarios piloto)
RUN_SEED=true

# Puerto web expuesto en el servidor (tablets / caja)
WEB_PORT=8080

# ─── API ───
JWT_SECRET=cambiar-por-string-largo-aleatorio-min-32-chars
JWT_EXPIRES_IN=12h
FISCAL_ENV=simulacion
FISCAL_SOFTWARE_ID=YALLPOS-001
FISCAL_SOFTWARE_PIN=pin-habilitacion
FISCAL_CERT_PATH=./certs/certificado.p12
FISCAL_CERT_PASSWORD=
FISCAL_TEST_SET_ID=

# Impresoras en la red del restaurante (API → red directa; Print Agent en PC caja)
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100
KITCHEN_PRINTER_IP=192.168.1.101
KITCHEN_PRINTER_PORT=9100

# Print Agent corre en cada PC de caja/tablet con impresora (localhost del navegador)
VITE_PRINT_AGENT_URL=http://127.0.0.1:9101
