generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── SaaS & Auth ───────────────────────────────────────────────

enum PlanTier {
  basic
  professional
  enterprise
  corporate
}

enum UserRole {
  owner
  manager
  cashier
  waiter
  kitchen
  baker
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      PlanTier @default(basic)
  isActive  Boolean  @default(true)
  settings  Json     @default("{}")
  createdAt DateTime @default(now())

  companies Company[]
  users     User[]
  roles     TenantRole[]
}

model TenantRole {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  slug        String
  description String?
  permissions String[]
  legacyRole  UserRole?
  isSystem    Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         UserRole
  roleId       String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  tenantRole TenantRole? @relation(fields: [roleId], references: [id])

  @@unique([tenantId, email])
}

// ─── Company & Branches ────────────────────────────────────────

enum BranchType {
  restaurant
  bakery
  cafe
  store
}

enum BusinessVertical {
  restaurant
  bakery
  cafe
  minimarket
  retail
}

model Company {
  id             String           @id @default(uuid())
  tenantId       String
  name           String
  nit            String?
  dv             String?
  razonSocial    String?
  regimen        String?          @default("simplificado")
  vertical       BusinessVertical @default(restaurant)
  email          String?
  phone          String?
  address        String?
  city           String?
  department     String?
  country        String           @default("CO")
  createdAt      DateTime         @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  branches Branch[]
  fiscalResolutions FiscalResolution[]
  taxDefinitions  TaxDefinition[]

  @@unique([tenantId, name])
}

model Branch {
  id        String     @id @default(uuid())
  companyId String
  name      String
  type      BranchType
  address   String?
  timezone  String     @default("America/Bogota")
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  company     Company        @relation(fields: [companyId], references: [id])
  areas       DiningArea[]
  tables      Table[]
  staff       Staff[]
  posSessions PosSession[]
  invoices    SalesInvoice[]
  kdsStations KdsStation[]
  categories  Category[]
  warehouses  Warehouse[]
  cashRegisters CashRegister[]
  reservations Reservation[]
}

// ─── Staff (legacy waiter model, coexists with User) ───────────

enum StaffRole {
  waiter
  cashier
  kitchen
  manager
  baker
}

model Staff {
  id        String    @id @default(uuid())
  companyId String
  branchId  String
  name      String
  phone     String?
  role      StaffRole
  isActive  Boolean   @default(true)

  branch Branch @relation(fields: [branchId], references: [id])
}

// ─── Catalog ───────────────────────────────────────────────────

enum ProductType {
  standard
  combo
  recipe
  weight_based
}

enum TaxKind {
  iva
  consumption
}

model TaxDefinition {
  id        String   @id @default(uuid())
  companyId String
  kind      TaxKind
  code      String
  name      String
  rate      Decimal
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
  @@index([companyId, kind, isActive])
}

model Category {
  id        String  @id @default(uuid())
  branchId  String
  parentId  String?
  name      String
  color     String?
  icon      String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  branch   Branch     @relation(fields: [branchId], references: [id])
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([branchId, parentId])
}

model Product {
  id          String      @id @default(uuid())
  branchId    String
  categoryId  String?
  name        String
  description String?
  type        ProductType @default(standard)
  isIngredient Boolean    @default(false)
  ivaTaxCode         String      @default("iva_19")
  consumptionTaxCode String      @default("none")
  isActive            Boolean             @default(true)
  imageUrl    String?
  course      String?     // appetizer|main|drink|dessert|bakery
  createdAt   DateTime    @default(now())

  category       Category?           @relation(fields: [categoryId], references: [id])
  variants       ProductVariant[]
  modifierGroups ProductModifierGroup[]
  recipeLines    ProductRecipeLine[] @relation("ProductRecipe")

  @@index([branchId, categoryId])
}

model ProductRecipeLine {
  id                  String  @id @default(uuid())
  productId           String
  ingredientVariantId String
  quantity            Decimal
  unit                String  @default("und")
  notes               String?
  sortOrder           Int     @default(0)

  product           Product        @relation("ProductRecipe", fields: [productId], references: [id], onDelete: Cascade)
  ingredientVariant ProductVariant @relation("IngredientInRecipe", fields: [ingredientVariantId], references: [id])

  @@unique([productId, ingredientVariantId])
  @@index([productId])
}

model ProductVariant {
  id           String  @id @default(uuid())
  productId    String
  sku          String?
  barcode      String?
  name         String
  price        Decimal @default(0)
  cost         Decimal @default(0)
  sellByWeight Boolean @default(false)
  unit         String  @default("und") // und, kg, g, lb
  isActive     Boolean @default(true)

  product Product @relation(fields: [productId], references: [id])
  stockLevels StockLevel[]
  usedInRecipes ProductRecipeLine[] @relation("IngredientInRecipe")

  @@index([productId])
  @@index([barcode])
}

model ModifierGroup {
  id        String  @id @default(uuid())
  branchId  String
  name      String
  minSelect Int     @default(0)
  maxSelect Int     @default(1)
  isActive  Boolean @default(true)

  products ProductModifierGroup[]
  options  ModifierOption[]
}

model ProductModifierGroup {
  id              String @id @default(uuid())
  productId       String
  modifierGroupId String
  sortOrder       Int    @default(0)

  product       Product       @relation(fields: [productId], references: [id])
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id])

  @@unique([productId, modifierGroupId])
}

model ModifierOption {
  id              String  @id @default(uuid())
  modifierGroupId String
  name            String
  priceDelta      Decimal @default(0)
  isActive        Boolean @default(true)

  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id])
}

// ─── Inventory ─────────────────────────────────────────────────

enum StockMovementType {
  sale
  purchase
  adjustment
  transfer_in
  transfer_out
  production
  waste
  return
}

model Warehouse {
  id       String  @id @default(uuid())
  branchId String
  name     String
  isDefault Boolean @default(false)
  isActive Boolean @default(true)

  branch      Branch         @relation(fields: [branchId], references: [id])
  stockLevels StockLevel[]
  movements   StockMovement[]
}

model StockLevel {
  id          String  @id @default(uuid())
  warehouseId String
  variantId   String
  quantity    Decimal @default(0)
  reserved    Decimal @default(0)
  minStock    Decimal @default(0)

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([warehouseId, variantId])
}

model StockMovement {
  id          String            @id @default(uuid())
  warehouseId String
  variantId   String
  type        StockMovementType
  quantity    Decimal
  reference   String?
  notes       String?
  createdAt   DateTime          @default(now())
  createdBy   String?

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([warehouseId, createdAt])
}

// ─── Customers ─────────────────────────────────────────────────

model Customer {
  id         String  @id @default(uuid())
  companyId  String
  docType    String  @default("CC") // CC, NIT, CE, PA
  docNumber  String?
  name       String
  email      String?
  phone      String?
  address    String?
  isActive   Boolean @default(true)
  createdAt  DateTime @default(now())

  @@index([companyId, docNumber])
}

// ─── Restaurant: Tables & Sessions ─────────────────────────────

model DiningArea {
  id       String  @id @default(uuid())
  branchId String
  name     String
  isActive Boolean @default(true)

  branch Branch  @relation(fields: [branchId], references: [id])
  tables Table[]
}

model Table {
  id           String  @id @default(uuid())
  branchId     String
  diningAreaId String
  name         String
  capacity     Int?
  isActive     Boolean @default(true)

  branch   Branch         @relation(fields: [branchId], references: [id])
  area     DiningArea     @relation(fields: [diningAreaId], references: [id])
  sessions TableSession[]
  reservations Reservation[]

  @@index([branchId, diningAreaId])
}

enum ReservationStatus {
  pending
  seated
  cancelled
  no_show
}

model Reservation {
  id             String            @id @default(uuid())
  branchId       String
  customerName   String
  customerPhone  String?
  guestsCount    Int
  reservedFor    DateTime
  tableId        String?
  status         ReservationStatus @default(pending)
  notes          String?
  tableSessionId String?
  createdAt      DateTime          @default(now())
  seatedAt       DateTime?

  branch Branch @relation(fields: [branchId], references: [id])
  table  Table? @relation(fields: [tableId], references: [id])

  @@index([branchId, reservedFor, status])
}

enum TableSessionStatus {
  open
  closed
  canceled
}

model TableSession {
  id             String             @id @default(uuid())
  branchId       String
  tableId        String
  waiterId       String
  status         TableSessionStatus
  openedAt       DateTime           @default(now())
  closedAt       DateTime?
  guestsCount    Int?
  openedByUserId String?

  table    Table          @relation(fields: [tableId], references: [id])
  invoices SalesInvoice[]

  @@index([branchId, tableId, status])
}

// ─── Cash Register ─────────────────────────────────────────────

model CashRegister {
  id       String  @id @default(uuid())
  branchId String
  name     String
  isActive Boolean @default(true)

  branch      Branch       @relation(fields: [branchId], references: [id])
  posSessions PosSession[]
}

enum PosSessionStatus {
  open
  closed
}

model PosSession {
  id             String           @id @default(uuid())
  branchId       String
  cashRegisterId String?
  userId         String
  status         PosSessionStatus
  openedAt       DateTime         @default(now())
  closedAt       DateTime?
  openingCash    Decimal          @default(0)
  closingCash    Decimal          @default(0)
  expectedCash   Decimal          @default(0)
  cashDifference Decimal          @default(0)
  notes          String?

  branch       Branch        @relation(fields: [branchId], references: [id])
  cashRegister CashRegister? @relation(fields: [cashRegisterId], references: [id])
  invoices     SalesInvoice[]
  movements    CashMovement[]

  @@index([branchId, status])
}

enum CashMovementType {
  withdrawal
  deposit
  expense
}

model CashMovement {
  id        String           @id @default(uuid())
  sessionId String
  type      CashMovementType
  amount    Decimal
  reason    String?
  createdAt DateTime         @default(now())
  createdBy String?

  session PosSession @relation(fields: [sessionId], references: [id])
}

// ─── Sales ─────────────────────────────────────────────────────

enum ServiceType {
  dine_in
  takeaway
  delivery
  counter // panadería mostrador
}

enum InvoiceStatus {
  draft
  sent_to_kitchen
  paid
  voided
  refunded
}

model SalesInvoice {
  id        String  @id @default(uuid())
  companyId String
  branchId  String
  sessionId String?
  customerId String?

  invoiceNumber String?
  idempotencyKey String? @unique

  status      InvoiceStatus
  serviceType ServiceType

  tableSessionId String?
  tableSession   TableSession? @relation(fields: [tableSessionId], references: [id])
  tableId        String?
  waiterId       String?
  guestsCount    Int?
  notes          String?

  deliveryName      String?
  deliveryPhone     String?
  deliveryAddress   String?
  deliveryReference String?
  deliveryFee       Decimal @default(0)
  deliveryStatus    String?

  pickupName        String?
  pickupPhone       String?
  pickupCode        String?
  pickupNotifiedAt  DateTime?
  tableReadyNotifiedAt DateTime?
  tableReadyServedAt     DateTime?
  tableReadyOverdueNotifiedAt DateTime?

  tipAmount    Decimal @default(0)
  printedCount Int     @default(0)

  subtotal       Decimal @default(0)
  discount       Decimal @default(0)
  consumptionTax Decimal @default(0)
  tax            Decimal @default(0)
  total          Decimal @default(0)

  createdAt DateTime @default(now())
  paidAt    DateTime?
  voidedAt  DateTime?

  lines    SalesInvoiceLine[]
  payments Payment[]
  fiscalDocuments ElectronicDocument[]

  branch  Branch      @relation(fields: [branchId], references: [id])
  session PosSession? @relation(fields: [sessionId], references: [id])

  @@unique([branchId, invoiceNumber])
  @@index([branchId, createdAt])
  @@index([status])
}

model SalesInvoiceLine {
  id           String  @id @default(uuid())
  invoiceId    String
  variantId    String
  nameSnapshot String
  course       String?
  qty          Decimal
  unitPrice    Decimal
  weight       Decimal? // para venta por peso (panadería)

  lineNotes    String?
  ivaTaxCode              String   @default("iva_19")
  consumptionTaxCode      String   @default("none")
  ivaRateSnapshot         Decimal?
  consumptionRateSnapshot Decimal?
  lineSubtotal            Decimal  @default(0)
  lineDiscount            Decimal  @default(0)
  lineConsumptionTax      Decimal  @default(0)
  lineTax                 Decimal  @default(0)
  lineTotal               Decimal  @default(0)

  invoice   SalesInvoice        @relation(fields: [invoiceId], references: [id])
  modifiers SalesLineModifier[]

  @@index([invoiceId])
}

model SalesLineModifier {
  id                 String  @id @default(uuid())
  invoiceLineId      String
  nameSnapshot       String
  priceDeltaSnapshot Decimal @default(0)
  qty                Decimal @default(1)
  notes              String?

  line SalesInvoiceLine @relation(fields: [invoiceLineId], references: [id])

  @@index([invoiceLineId])
}

enum PaymentMethod {
  cash
  card
  transfer
  qr
  credit
  voucher
  mixed
}

model Payment {
  id        String        @id @default(uuid())
  invoiceId String
  method    PaymentMethod
  amount    Decimal
  reference String?
  tipAmount Decimal       @default(0)

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id])
}

// ─── KDS ───────────────────────────────────────────────────────

enum KdsItemStatus {
  new
  preparing
  ready
  served
  canceled
}

enum KdsTicketStatus {
  new
  preparing
  ready
  served
  canceled
}

model KdsStation {
  id       String  @id @default(uuid())
  branchId String
  name     String
  isActive Boolean @default(true)

  branch       Branch           @relation(fields: [branchId], references: [id])
  routingRules KdsRoutingRule[]
  KdsItem      KdsItem[]
}

model KdsRoutingRule {
  id        String  @id @default(uuid())
  branchId  String
  stationId String
  variantId String?
  course    String?

  station KdsStation @relation(fields: [stationId], references: [id])
}

model KdsTicket {
  id        String          @id @default(uuid())
  branchId  String
  invoiceId String
  status    KdsTicketStatus @default(new)
  tableId   String?
  waiterId  String?
  createdAt DateTime        @default(now())

  items KdsItem[]

  @@unique([branchId, invoiceId])
  @@index([branchId, status, createdAt])
}

model KdsItem {
  id            String        @id @default(uuid())
  ticketId      String
  invoiceLineId String
  stationId     String
  course        String?
  status        KdsItemStatus @default(new)
  startedAt     DateTime?
  readyAt       DateTime?
  servedAt      DateTime?
  createdAt     DateTime      @default(now())

  ticket  KdsTicket  @relation(fields: [ticketId], references: [id])
  station KdsStation @relation(fields: [stationId], references: [id])

  @@index([stationId, status, createdAt])
}

// ─── Fiscal / DIAN (desarrollo propio) ─────────────────────────

enum FiscalDocType {
  invoice           // 01
  pos_equivalent    // 20 - Documento Equivalente POS
  credit_note       // 91
  debit_note        // 92
}

enum FiscalDocStatus {
  pending
  validating
  accepted
  rejected
  contingency
  cancelled
}

model FiscalResolution {
  id          String        @id @default(uuid())
  companyId   String
  docType     FiscalDocType
  prefix      String
  fromNumber  Int
  toNumber    Int
  currentNumber Int         @default(0)
  validFrom   DateTime
  validTo     DateTime
  technicalKey String?
  isActive    Boolean       @default(true)
  isContingency Boolean     @default(false)
  createdAt   DateTime      @default(now())

  company   Company              @relation(fields: [companyId], references: [id])
  documents ElectronicDocument[]

  @@index([companyId, docType, isActive])
}

model ElectronicDocument {
  id           String          @id @default(uuid())
  companyId    String
  invoiceId    String?
  resolutionId String
  docType      FiscalDocType
  docNumber    String
  prefix       String
  fullNumber   String          @unique
  cufe         String?
  cude         String?
  status       FiscalDocStatus @default(pending)
  xmlContent   String?         @db.Text
  pdfUrl       String?
  customerDoc  String?
  customerName String?
  subtotal     Decimal         @default(0)
  tax          Decimal         @default(0)
  total        Decimal         @default(0)
  retryCount   Int             @default(0)
  lastError    String?
  dianResponse Json?
  issuedAt     DateTime        @default(now())
  acceptedAt   DateTime?
  emailedAt    DateTime?

  resolution FiscalResolution @relation(fields: [resolutionId], references: [id])
  invoice    SalesInvoice?    @relation(fields: [invoiceId], references: [id])
  contingencyLogs FiscalContingencyLog[]

  @@index([companyId, status])
  @@index([invoiceId])
}

model FiscalContingencyLog {
  id         String   @id @default(uuid())
  documentId String
  reason     String
  syncedAt   DateTime?
  createdAt  DateTime @default(now())

  document ElectronicDocument @relation(fields: [documentId], references: [id])
}

// ─── Audit ─────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  payload   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([entity, entityId])
}
